{
  "name": "ahs",
  "version": "0.1.0",
  "private": true,
  "description": "Agent History Standard (AHS) — offline exchange and consumption format for coding agent session history",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vite-node test/e2e/smoke.ts && vite-node test/e2e/adapter-chains.ts",
    "check:report": "vite-node scripts/check-report.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "zod": "^4.0.0"
  }
}
